# Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# MongoDB
MONGO_INITDB_DATABASE=healthcare_db
MONGO_URI=mongodb://mongodb:27017/healthcare_db

# JWT Secrets (Change these in production!)
JWT_SECRET=your_jwt_secret_key_change_in_production
AUTH_JWT_SECRET=your_auth_service_secret_key_change_in_production
PATIENT_JWT_SECRET=your_patient_service_secret_key_change_in_production
APPOINTMENT_JWT_SECRET=your_appointment_service_secret_key_change_in_production
CONSULTATION_JWT_SECRET=your_consultation_service_secret_key_change_in_production
PAYMENT_JWT_SECRET=your_payment_service_secret_key_change_in_production
DOCTOR_JWT_SECRET=your_doctor_service_secret_key_change_in_production
SYMPTOM_CHECKER_JWT_SECRET=your_symptom_checker_service_secret_key_change_in_production
NOTIFICATION_JWT_SECRET=your_notification_service_secret_key_change_in_production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDGRID_API_KEY=your-sendgrid-api-key

# Payment (Stripe)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Frontend
VITE_API_BASE_URL=http://api-gateway:5000
CLIENT_URL=http://localhost:5173

# Jitsi Configuration
JITSI_DOMAIN=meet.jit.si

# Node Environment
NODE_ENV=production

# Service Ports
API_GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
PATIENT_SERVICE_PORT=5002
APPOINTMENT_SERVICE_PORT=5003
CONSULTATION_SERVICE_PORT=5004
PAYMENT_SERVICE_PORT=5005
DOCTOR_SERVICE_PORT=5006
SYMPTOM_CHECKER_PORT=5007
NOTIFICATION_SERVICE_PORT=5008
MONGODB_PORT=27017
FRONTEND_PORT=5173
